# -----------------------------
# Global demo mode
# -----------------------------
APP_ENV=local
CAW_MODE=mock
LLM_MODE=mock
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------
# Cobo Agentic Wallet - real mode
# Fill these only when switching CAW_MODE=real.
# -----------------------------
AGENT_WALLET_API_URL=https://api.agenticwallet.cobo.com
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_ID=
CAW_CHAIN_ID=SETH
CAW_TOKEN_ID=SETH
CAW_AGENT_ADDRESS=

# -----------------------------
# Z.AI / GLM-5.1 - real mode
# Fill these only when switching LLM_MODE=real.
# Z.AI is OpenAI-compatible; backend uses openai>=1.0 when available.
# -----------------------------
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_MODEL=glm-5.1

# -----------------------------
# Deployed contract addresses - replace after deployment.
# -----------------------------
CHAIN_ID=11155111
RPC_URL=
PRIVATE_KEY=
MOCK_USDC_ADDRESS=
AGENTIC_COMMERCE_ADDRESS=
